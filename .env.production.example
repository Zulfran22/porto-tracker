# Production environment reference (Render + Neon Postgres + Backblaze B2 —
# semuanya free tier TANPA kartu kredit).
# Deploy pakai render.yaml (New → Blueprint di dashboard Render); nilai-nilai
# rahasia di bawah akan diminta saat blueprint dibuat. JANGAN pakai
# .env.example (itu template LOCAL DEV yang sengaja debug on).

APP_NAME=WealthID
APP_ENV=production
# Generate locally with `php artisan key:generate --show` and paste the value.
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.onrender.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_STACK=stderr
LOG_LEVEL=info

# Neon (https://neon.tech) — free Postgres yang TIDAK kedaluwarsa, tanpa kartu.
# JANGAN pakai Postgres free bawaan Render — database itu DIHAPUS setelah 30
# hari. Ambil connection string dari dashboard Neon ("Connection Details"),
# pastikan sslmode=require. Region terdekat: ap-southeast-1 (Singapura).
DB_CONNECTION=pgsql
DB_URL=postgres://USER:PASSWORD@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# File kontrak yang di-upload user → Backblaze B2 (S3-compatible, 10GB gratis,
# tanpa kartu kredit). Container Render bersifat EPHEMERAL — tanpa ini, file
# upload hilang setiap redeploy/sleep-wake. Di backblaze.com: buat bucket
# (private) → App Keys → buat key untuk bucket itu. "Endpoint" tertera di
# detail bucket (mis. s3.ap-southeast-002.backblazeb2.com) — region-nya adalah
# potongan tengah endpoint itu (mis. ap-southeast-002).
UPLOADS_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-002
AWS_BUCKET=wealtid-kontrak
AWS_ENDPOINT=https://s3.ap-southeast-002.backblazeb2.com
AWS_USE_PATH_STYLE_ENDPOINT=true

# "Lupa password" mengirim email — dengan MAIL_MAILER=log email hanya masuk ke
# log server dan user tidak pernah menerimanya. Arahkan ke SMTP sungguhan
# sebelum launch (Resend/Mailgun/Brevo punya free tier), contoh:
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.resend.com
# MAIL_PORT=587
# MAIL_USERNAME=resend
# MAIL_PASSWORD=re_xxxxxxxx
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# `php artisan serve` default-nya single-process — satu request lambat memblokir
# semua request lain. Ini mengaktifkan beberapa worker di PHP built-in server.
PHP_CLI_SERVER_WORKERS=4

VITE_APP_NAME="${APP_NAME}"

GOLD_PEGADAIAN_MARKUP=1.04
GOLD_FALLBACK_XAU_PRICE=3280

# Fill this in — without it, production exceptions are only visible if
# someone is actively tailing logs. Get a DSN from https://sentry.io.
SENTRY_LARAVEL_DSN=

# Token rahasia endpoint /cron/recurring-apply. Render free tidur setelah 15
# menit idle dan schedule:work ikut tidur, jadi job harian dipicu dari luar:
# daftar di cron-job.org (gratis) dengan URL
#   https://your-app.onrender.com/cron/recurring-apply?token=NILAI_TOKEN_INI
# jadwal harian 00:05 WIB. Job kedua (opsional, anti cold-start): ping
# https://your-app.onrender.com/up tiap 10 menit — 750 jam gratis/bulan Render
# cukup untuk satu service nyala 24/7. Generate token: `openssl rand -hex 32`.
# Kosong = endpoint mati (403).
CRON_TOKEN=
