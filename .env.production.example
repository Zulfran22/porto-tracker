# Production environment reference (Koyeb + Neon Postgres + Cloudflare R2).
# Paste these into the Koyeb service's Environment Variables — DO NOT use
# .env.example (that file is the LOCAL DEV template and intentionally ships
# with debug on).

APP_NAME=WealthID
APP_ENV=production
# Generate locally with `php artisan key:generate --show` and paste the value.
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.koyeb.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_STACK=stderr
LOG_LEVEL=info

# Neon (https://neon.tech) — free Postgres yang TIDAK kedaluwarsa. Ambil
# connection string dari dashboard Neon ("Connection Details") dan pastikan
# sslmode=require ikut serta. Region terdekat: ap-southeast-1 (Singapura).
DB_CONNECTION=pgsql
DB_URL=postgres://USER:PASSWORD@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# File kontrak yang di-upload user → Cloudflare R2 (S3-compatible, 10GB
# gratis). Container Koyeb bersifat EPHEMERAL — tanpa ini, file upload hilang
# setiap redeploy/scale-to-zero. Buat bucket + API token di dash.cloudflare.com
# → R2 → "Manage R2 API Tokens" (izin Object Read & Write).
UPLOADS_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=wealtid-kontrak
AWS_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
AWS_USE_PATH_STYLE_ENDPOINT=true

# "Lupa password" mengirim email — dengan MAIL_MAILER=log email hanya masuk ke
# log server dan user tidak pernah menerimanya. Arahkan ke SMTP sungguhan
# sebelum launch (Resend/Mailgun/Brevo punya free tier), contoh:
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.resend.com
# MAIL_PORT=587
# MAIL_USERNAME=resend
# MAIL_PASSWORD=re_xxxxxxxx
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# `php artisan serve` default-nya single-process — satu request lambat memblokir
# semua request lain. Ini mengaktifkan beberapa worker di PHP built-in server.
PHP_CLI_SERVER_WORKERS=4

VITE_APP_NAME="${APP_NAME}"

GOLD_PEGADAIAN_MARKUP=1.04
GOLD_FALLBACK_XAU_PRICE=3280

# Fill this in — without it, production exceptions are only visible if
# someone is actively tailing logs. Get a DSN from https://sentry.io.
SENTRY_LARAVEL_DSN=

# Token rahasia endpoint /cron/recurring-apply. Koyeb free scale-to-zero
# menidurkan schedule:work, jadi job harian dipicu dari luar: daftar di
# cron-job.org (gratis) dengan URL
#   https://your-app.koyeb.app/cron/recurring-apply?token=NILAI_TOKEN_INI
# jadwal harian 00:05 WIB. Generate token: `openssl rand -hex 32`.
# Kosong = endpoint mati (403).
CRON_TOKEN=
