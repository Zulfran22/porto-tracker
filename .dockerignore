# Tanpa file ini, `COPY . .` di Dockerfile menyeret node_modules/vendor lokal,
# symlink public/storage (bikin build gagal di Windows), dan — paling bahaya —
# .env berisi secret ikut terpanggang ke dalam image.
.git
.github
node_modules
vendor
public/build
public/hot
public/storage
.env
.env.backup
.env.production
storage/app/private/*
!storage/app/private/.gitignore
storage/app/public/*
!storage/app/public/.gitignore
storage/framework/cache/data/*
storage/framework/sessions/*
storage/framework/views/*
!storage/framework/views/.gitignore
storage/logs/*
!storage/logs/.gitignore
Thumbs.db
.DS_Store
