APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Disk file kontrak yang di-upload user — 'local' untuk dev/test; produksi
# (Koyeb, filesystem ephemeral) pakai 's3' yang diarahkan ke Cloudflare R2.
UPLOADS_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

GOLD_PEGADAIAN_MARKUP=1.04
GOLD_FALLBACK_XAU_PRICE=3280

# Error monitoring — leave blank to disable (the SDK silently no-ops with no
# DSN). Get a DSN from https://sentry.io if you want production errors
# reported instead of only visible in logs.
SENTRY_LARAVEL_DSN=

# Token webhook /cron/recurring-apply (pemicu eksternal job harian di host
# yang scale-to-zero). Kosong = endpoint mati (403) — aman untuk dev lokal.
CRON_TOKEN=

# Railway Native production reference:
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://your-railway-domain.up.railway.app
# LOG_CHANNEL=stderr
# LOG_STACK=stderr
# LOG_LEVEL=info
# DB_CONNECTION=pgsql
# DB_URL=${{Postgres.DATABASE_URL}}
# SESSION_DRIVER=database
# CACHE_STORE=database
# QUEUE_CONNECTION=database
# FILESYSTEM_DISK=local
